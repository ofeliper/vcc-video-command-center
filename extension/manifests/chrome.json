{
  "manifest_version": 3,
  "name": "VCC - Video Command Center",
  "version": "0.5.0",
  "description": "Centro de controle local para players HTML5, voltado a uso pessoal.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/gm-compat.js", "src/tampermonkey-vcc.user.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/service-worker.js"
  },
  "action": {
    "default_title": "Open VCC control panel",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  }
}
